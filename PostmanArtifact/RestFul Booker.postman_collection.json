        {
          "name": "CreateBooking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var requestBody = JSON.parse(pm.request.body.raw);",
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 3000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "pm.test(\"Response has bookingid and booking object\", function () {",
                  "    pm.expect(jsonData).to.have.property(\"bookingid\");",
                  "    pm.expect(jsonData.bookingid).to.be.a(\"number\");",
                  "",
                  "    pm.expect(jsonData).to.have.property(\"booking\");",
                  "    pm.expect(jsonData.booking).to.be.an(\"object\");",
                  "",
                  "    pm.environment.set(\"bookingId\", jsonData.bookingid);",
                  "});",
                  "",
                  "pm.test(\"Booking firstname is correct\", function () {",
                  "    pm.expect(jsonData.booking.firstname).to.eql(requestBody.firstname);",
                  "});",
                  "",
                  "pm.test(\"Booking lastname is correct\", function () {",
                  "    pm.expect(jsonData.booking.lastname).to.eql(requestBody.lastname);",
                  "});",
                  "",
                  "pm.test(\"Booking totalprice is correct\", function () {",
                  "    pm.expect(jsonData.booking.totalprice).to.eql(requestBody.totalprice);",
                  "});",
                  "",
                  "pm.test(\"Booking depositpaid is correct\", function () {",
                  "    pm.expect(jsonData.booking.depositpaid).to.eql(requestBody.depositpaid);",
                  "});",
                  "",
                  "pm.test(\"Booking dates are correct\", function () {",
                  "    pm.expect(jsonData.booking.bookingdates.checkin).to.eql(requestBody.bookingdates.checkin);",
                  "    pm.expect(jsonData.booking.bookingdates.checkout).to.eql(requestBody.bookingdates.checkout);",
                  "});",
                  "",
                  "pm.test(\"Additional needs is correct\", function () {",
                  "    pm.expect(jsonData.booking.additionalneeds).to.eql(requestBody.additionalneeds);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
