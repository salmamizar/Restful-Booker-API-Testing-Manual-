        {
          "name": "PartialUpdateBooking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var requestBody = JSON.parse(pm.request.body.raw);",
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 3000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "pm.test(\"Patched fields are updated correctly\", function () {",
                  "",
                  "    Object.keys(requestBody).forEach(function(field){",
                  "",
                  "        if(typeof requestBody[field] === \"object\"){",
                  "",
                  "            Object.keys(requestBody[field]).forEach(function(subField){",
                  "",
                  "                pm.expect(jsonData[field][subField])",
                  "                  .to.eql(requestBody[field][subField]);",
                  "",
                  "            });",
                  "",
                  "        } else {",
                  "",
                  "            pm.expect(jsonData[field])",
                  "              .to.eql(requestBody[field]);",
                  "",
                  "        }",
                  "",
                  "    });",
                  "",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
